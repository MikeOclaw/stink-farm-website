# Stripe - get these from your Stripe dashboard
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Your Stripe Price ID for the game (create in Stripe dashboard)
STRIPE_PRICE_ID=price_...

# Plausible Analytics domain (e.g. stinkfarmgame.com)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=stinkfarmgame.com

# App URL (used for Stripe success/cancel redirect URLs)
NEXT_PUBLIC_APP_URL=https://stinkfarmgame.com
